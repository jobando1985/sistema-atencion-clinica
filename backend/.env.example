# Configuración del backend - copiar a .env y completar valores

# Puerto del servidor (Render lo asigna automáticamente)
PORT=4000

# Conexión a PostgreSQL (Render provee DATABASE_URL automáticamente)
DATABASE_URL=postgresql://usuario:password@host:5432/clinica

# Secreto para firmar JWT (generar uno largo y aleatorio)
JWT_SECRET=cambiar_este_valor_por_uno_seguro_y_largo

# Tiempo de expiración del token
JWT_EXPIRES_IN=12h

# Origen permitido por CORS (en producción, dominio del frontend)
CORS_ORIGIN=*

# Entorno
NODE_ENV=development
